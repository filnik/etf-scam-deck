<div class="nav-controls">
  <button class="nav-btn" id="btnPrev" aria-label="Previous slide">←</button>
  <div class="nav-counter"><span class="current" id="navCurrent">01</span> / <span id="navTotal">28</span></div>
  <button class="nav-btn" id="btnNext" aria-label="Next slide">→</button>
</div>

<script>
(function() {
  'use strict';

  const slides = document.querySelectorAll('.slide');
  const totalSlides = slides.length;
  const progressBar = document.getElementById('progressBar');
  const navCurrent = document.getElementById('navCurrent');
  const navTotal = document.getElementById('navTotal');
  const btnPrev = document.getElementById('btnPrev');
  const btnNext = document.getElementById('btnNext');

  let currentIndex = 0;
  let chartsInitialized = new Set();

  navTotal.textContent = String(totalSlides).padStart(2, '0');

  function showSlide(idx) {
    if (idx < 0 || idx >= totalSlides) return;
    slides.forEach((s, i) => {
      s.classList.remove('is-active', 'is-prev');
      if (i === idx) s.classList.add('is-active');
      else if (i < idx) s.classList.add('is-prev');
    });
    currentIndex = idx;
    const pct = ((idx + 1) / totalSlides) * 100;
    progressBar.style.width = pct + '%';
    navCurrent.textContent = String(idx + 1).padStart(2, '0');
    btnPrev.disabled = idx === 0;
    btnNext.disabled = idx === totalSlides - 1;

    // Trigger counter animations on entering slide
    animateCountersInSlide(slides[idx]);
    // Init charts on demand
    initChartsInSlide(slides[idx]);
  }

  function animateCounter(el) {
    if (el.dataset.animated === 'true') {
      // re-animate on revisit
    }
    const target = parseFloat(el.dataset.counter);
    const decimals = parseInt(el.dataset.decimals || '0', 10);
    const prefix = el.dataset.prefix || '';
    const suffix = el.dataset.suffix || '';
    const duration = 1600;
    const startTime = performance.now();
    el.dataset.animated = 'true';

    function tick(now) {
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);
      // easeOutExpo
      const eased = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
      const current = target * eased;
      let display;
      if (decimals > 0) {
        display = current.toFixed(decimals);
      } else {
        display = Math.floor(current).toLocaleString('it-IT');
      }
      el.textContent = prefix + display + suffix;
      if (progress < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  function animateCountersInSlide(slide) {
    const counters = slide.querySelectorAll('[data-counter]');
    counters.forEach(c => {
      // reset and animate fresh each time
      c.dataset.animated = 'false';
      animateCounter(c);
    });
  }

  function initChartsInSlide(slide) {
    const canvases = slide.querySelectorAll('canvas');
    canvases.forEach(canvas => {
      if (chartsInitialized.has(canvas.id)) return;
      chartsInitialized.add(canvas.id);
      buildChart(canvas);
    });
  }

  function buildChart(canvas) {
    const id = canvas.id;
    const ctx = canvas.getContext('2d');
    Chart.defaults.color = '#b0b0c0';
    Chart.defaults.font.family = "'Inter', sans-serif";
    Chart.defaults.font.size = 13;
    Chart.defaults.plugins.zoom = {
      zoom: {
        wheel: { enabled: true },
        drag: { enabled: true, backgroundColor: 'rgba(0,217,255,0.25)', borderColor: '#00d9ff', borderWidth: 2, drawTime: 'afterDraw' },
        mode: 'xy'
      },
      pan: { enabled: true, mode: 'xy', modifierKey: 'shift' }
    };
    canvas.addEventListener('dblclick', () => { const c = Chart.getChart(canvas); if (c && c.resetZoom) c.resetZoom(); });

    if (id === 'chart-stop-loss') {
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: ['Baseline\n(mai vendere)', 'Trailing −15%', 'Trailing −20%', 'ATR 3×'],
          datasets: [{
            label: 'CAGR',
            data: [36.2, 3.1, 5.8, 4.2],
            backgroundColor: ['#00d26a', '#ff4757', '#ff4757', '#ff4757'],
            borderRadius: 8,
            borderSkipped: false
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: '#1a1a36',
              borderColor: 'rgba(255,255,255,0.1)',
              borderWidth: 1,
              padding: 12,
              callbacks: {
                label: (ctx) => ctx.parsed.y.toFixed(1) + '% CAGR'
              }
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              max: 42,
              grid: { color: 'rgba(255,255,255,0.05)' },
              ticks: {
                callback: (v) => v + '%',
                font: { family: "'JetBrains Mono'" }
              }
            },
            x: {
              grid: { display: false },
              ticks: {
                font: { weight: 600 },
                color: '#f0f0f5'
              }
            }
          }
        }
      });
    }

    if (id === 'chart-spy-ytd') {
      const tickers = ['MSFT','AAPL','NVDA','AMZN','GOOGL','META','BRK-B','TSLA','LLY','AVGO','JPM','V','UNH','XOM','MA'];
      const ytd = [8, 1, 28, 6, 9, 12, 4, -15, -10, 22, 3, 2, -8, 5, 2];
      const colors = ytd.map(v => v >= 0 ? '#00d26a' : '#ff4757');
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: tickers,
          datasets: [{
            label: 'YTD 2026 %',
            data: ytd,
            backgroundColor: colors,
            borderRadius: 6,
            borderSkipped: false
          }]
        },
        options: {
          indexAxis: 'y',
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: '#1a1a36',
              borderColor: 'rgba(255,255,255,0.1)',
              borderWidth: 1,
              padding: 12,
              callbacks: {
                label: (ctx) => 'YTD ' + (ctx.parsed.x >= 0 ? '+' : '') + ctx.parsed.x + '%'
              }
            }
          },
          scales: {
            x: {
              grid: { color: 'rgba(255,255,255,0.05)' },
              ticks: {
                callback: (v) => (v >= 0 ? '+' : '') + v + '%',
                font: { family: "'JetBrains Mono'" }
              }
            },
            y: {
              grid: { display: false },
              ticks: {
                font: { weight: 700, family: "'JetBrains Mono'", size: 11 },
                color: '#f0f0f5'
              }
            }
          }
        }
      });
    }

    if (id === 'chart-cagr-3way') {
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: ['SPY · S&P 500', 'QQQ · NASDAQ 100', 'Top2-EW-Hyst', 'P/E Switch + oro', 'NoRot2 · NVDA+AVGO'],
          datasets: [{
            label: 'CAGR 16y',
            data: [8.18, 11.32, 14.30, 24.46, 33.41],
            backgroundColor: ['#ff4757', '#ffa502', '#00d9ff', '#0a84ff', '#00d26a'],
            borderRadius: 12,
            borderSkipped: false,
            barPercentage: 0.65
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: '#1a1a36',
              borderColor: 'rgba(255,255,255,0.1)',
              borderWidth: 1,
              padding: 12,
              callbacks: {
                label: (ctx) => '+' + ctx.parsed.y.toFixed(2) + '% CAGR'
              }
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              max: 35,
              grid: { color: 'rgba(255,255,255,0.05)' },
              ticks: {
                callback: (v) => '+' + v + '%',
                font: { family: "'JetBrains Mono'" }
              },
              title: { display: true, text: 'CAGR annuo', color: '#7a7a90', font: { size: 12 } }
            },
            x: {
              grid: { display: false },
              ticks: {
                font: { weight: 700, size: 13 },
                color: '#f0f0f5'
              }
            }
          }
        }
      });
    }

    if (id === 'chart-concentration') {
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: ['S&P 500 · 500 titoli', 'NASDAQ 100 · 100 titoli', 'Top2-EW-Hyst · 2 titoli'],
          datasets: [{
            label: 'CAGR 2010-2025',
            data: [8.18, 11.32, 14.30],
            backgroundColor: ['#ff4757', '#ffa502', '#00d9ff'],
            borderRadius: 12,
            borderSkipped: false,
            barPercentage: 0.6
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: '#1a1a36',
              borderColor: 'rgba(255,255,255,0.1)',
              borderWidth: 1,
              padding: 12,
              callbacks: {
                label: (ctx) => '+' + ctx.parsed.y.toFixed(2) + '% CAGR'
              }
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              max: 17,
              grid: { color: 'rgba(255,255,255,0.05)' },
              ticks: {
                callback: (v) => '+' + v + '%',
                font: { family: "'JetBrains Mono'" }
              },
              title: { display: true, text: 'CAGR annuo', color: '#7a7a90', font: { size: 12 } }
            },
            x: {
              grid: { display: false },
              ticks: {
                font: { weight: 700, size: 13 },
                color: '#f0f0f5'
              }
            }
          }
        }
      });
    }

    if (id === 'chart-pac-growth') {
      const years = ['2010','2011','2012','2013','2014','2015','2016','2017','2018','2019','2020','2021','2022','2023','2024','2025'];
      // Tutte equity curve REALI da un unico backtest (PAC €1k/mese, realistic mode,
      // regime dichiarativo, 2010-2025). P/E Switch = us_only (i ticker nativi
      // asiatici non hanno dati nel 2010).
      const spy =      [13, 25, 42, 68,  92,  108, 128, 170, 192, 236,  294,  380,  360,  425,  580,   675];
      const qqq =      [14, 27, 44, 72,  102, 126, 140, 203, 236, 301,  464,  608,  474,  648,  866,   1068];
      const top2 =     [14, 30, 52, 67,  98,  109, 117, 193, 216, 327,  593,  835,  736,  969,  1227,  1628];
      const momtop2 =  [10, 23, 39, 83,  108, 118, 172, 404, 401, 453,  683,  594,  785,  742,  1937,  3185];
      const peswitch = [11, 17, 26, 57,  80,  93,  173, 281, 265, 349,  677,  1355, 862,  1757, 4759,  6364];
      const norot2 =   [13, 26, 39, 65,  137, 219, 353, 689, 610, 844,  1548, 3037, 2113, 4824, 12282, 19328];
      new Chart(ctx, {
        type: 'line',
        data: {
          labels: years,
          datasets: [
            {
              label: 'SPY (S&P 500)',
              data: spy,
              borderColor: '#ff4757',
              backgroundColor: 'rgba(255,71,87,0.06)',
              borderWidth: 2.5,
              tension: 0.35,
              pointRadius: 0,
              pointHoverRadius: 6,
              fill: false
            },
            {
              label: 'QQQ (NASDAQ 100)',
              data: qqq,
              borderColor: '#ffa502',
              backgroundColor: 'rgba(255,165,2,0.06)',
              borderWidth: 2.5,
              tension: 0.35,
              pointRadius: 0,
              pointHoverRadius: 6,
              fill: false
            },
            {
              label: 'Top2-EW-Hyst',
              data: top2,
              borderColor: '#00d9ff',
              backgroundColor: 'rgba(0,217,255,0.08)',
              borderWidth: 3,
              tension: 0.35,
              pointRadius: 0,
              pointHoverRadius: 6,
              fill: false
            },
            {
              label: 'Mom-Top2-Hyst',
              data: momtop2,
              borderColor: '#c77dff',
              backgroundColor: 'rgba(199,125,255,0.08)',
              borderWidth: 3,
              tension: 0.35,
              pointRadius: 0,
              pointHoverRadius: 6,
              fill: false
            },
            {
              label: 'P/E Switch + oro',
              data: peswitch,
              borderColor: '#0a84ff',
              backgroundColor: 'rgba(10,132,255,0.08)',
              borderWidth: 3,
              tension: 0.35,
              pointRadius: 0,
              pointHoverRadius: 6,
              fill: false
            },
            {
              label: 'NoRot2 (NVDA+AVGO)',
              data: norot2,
              borderColor: '#00d26a',
              backgroundColor: 'rgba(0,210,106,0.12)',
              borderWidth: 3.5,
              tension: 0.35,
              pointRadius: 0,
              pointHoverRadius: 7,
              fill: true
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'top',
              align: 'end',
              labels: {
                usePointStyle: true,
                pointStyle: 'line',
                padding: 18,
                font: { weight: 600, size: 13 }
              }
            },
            tooltip: {
              mode: 'index',
              intersect: false,
              backgroundColor: '#1a1a36',
              borderColor: 'rgba(255,255,255,0.1)',
              borderWidth: 1,
              padding: 14,
              callbacks: {
                label: (ctx) => ctx.dataset.label + ': €' + ctx.parsed.y.toLocaleString('it-IT') + 'K'
              }
            }
          },
          scales: {
            y: {
              type: 'logarithmic',
              grid: { color: 'rgba(255,255,255,0.05)' },
              ticks: {
                callback: (v) => {
                  const f = Math.log10(v) % 1;
                  const nice = Math.abs(f) < 0.04 || Math.abs(f - 1) < 0.04 || Math.abs(f - 0.4771) < 0.05;
                  return nice ? '€' + (v >= 1000 ? (v / 1000) + 'M' : v + 'K') : '';
                },
                font: { family: "'JetBrains Mono'" }
              },
              title: { display: true, text: 'Valore portfolio (€) · scala log', color: '#7a7a90', font: { size: 12 } }
            },
            x: {
              grid: { display: false },
              ticks: {
                font: { family: "'JetBrains Mono'", size: 11 },
                color: '#b0b0c0',
                maxRotation: 0,
                autoSkip: true,
                autoSkipPadding: 10
              }
            }
          }
        }
      });
    }

    // === CRASH TEST CHARTS ===
    if (id.startsWith('chart-crash-')) {
      const crashData = JSON.parse(document.getElementById('crash-data').textContent);
      const parts = id.replace('chart-crash-', '').split('-');
      const crashId = parts[0]; // dotcom, gfc2008, memory2018, rate2022
      const variant = parts[1]; // 1y or bars
      const crash = crashData.crashes.find(c => c.id === crashId);
      if (!crash) return;

      const portfolioColors = {
        SPY: '#ff4757',
        PESwitch: '#0a84ff',
        NoRot2: '#00d26a',
        NoRot2_TS: '#b388ff'
      };
      const portfolioLabels = {
        SPY: 'SPY (PAC puro)',
        PESwitch: 'P/E Switch + oro',
        NoRot2: 'NVDA+AVGO + 15% oro',
        NoRot2_TS: 'NVDA+AVGO + oro · TS−15%'
      };

      if (variant === '1y') {
        // Line chart with 3 portfolio timelines (1y_before)
        const scenarios = crash.scenarios.filter(s => s.entry_offset === '1y_before');
        // Use longest timeline as x-axis
        const maxTimeline = scenarios.reduce((max, s) =>
          s.timeline_dates.length > max.length ? s.timeline_dates : max, []);
        const peakLineIdx = maxTimeline.findIndex(d => d >= crash.peak_date);
        const troughLineIdx = maxTimeline.findIndex(d => d >= crash.trough_date);

        const datasets = scenarios.map(s => ({
          label: portfolioLabels[s.portfolio],
          data: s.timeline_values,
          borderColor: portfolioColors[s.portfolio],
          backgroundColor: portfolioColors[s.portfolio] + '15',
          borderWidth: 2.5,
          tension: 0.3,
          pointRadius: 0,
          pointHoverRadius: 5,
          fill: false
        }));

        new Chart(ctx, {
          type: 'line',
          data: {
            labels: maxTimeline.map(d => d.substring(0, 7)),
            datasets: datasets
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: {
                position: 'top',
                align: 'end',
                labels: { usePointStyle: true, pointStyle: 'line', padding: 12, font: { size: 11, weight: 600 } }
              },
              tooltip: {
                mode: 'index',
                intersect: false,
                backgroundColor: '#1a1a36',
                borderColor: 'rgba(255,255,255,0.1)',
                borderWidth: 1,
                padding: 10,
                callbacks: {
                  label: (ctx) => ctx.dataset.label + ': ' + (ctx.parsed.y >= 0 ? '+' : '') + ctx.parsed.y.toFixed(1) + '%'
                }
              },
              annotation: {
                annotations: {
                  peakLine: {
                    type: 'line',
                    xMin: peakLineIdx, xMax: peakLineIdx,
                    borderColor: 'rgba(255,165,2,0.7)',
                    borderWidth: 2,
                    borderDash: [6, 4],
                    label: {
                      display: true,
                      content: '⚠ PEAK',
                      position: 'start',
                      backgroundColor: 'rgba(255,165,2,0.85)',
                      color: '#0f0f1a',
                      font: { size: 10, weight: 700, family: "'JetBrains Mono'" },
                      padding: { x: 6, y: 3 },
                      borderRadius: 4,
                      yAdjust: -2
                    }
                  },
                  troughLine: {
                    type: 'line',
                    xMin: troughLineIdx, xMax: troughLineIdx,
                    borderColor: 'rgba(255,71,87,0.7)',
                    borderWidth: 2,
                    borderDash: [6, 4],
                    label: {
                      display: true,
                      content: '▼ TROUGH',
                      position: 'end',
                      backgroundColor: 'rgba(255,71,87,0.85)',
                      color: '#fff',
                      font: { size: 10, weight: 700, family: "'JetBrains Mono'" },
                      padding: { x: 6, y: 3 },
                      borderRadius: 4
                    }
                  }
                }
              }
            },
            scales: {
              y: {
                grid: { color: 'rgba(255,255,255,0.05)' },
                ticks: {
                  callback: (v) => (v >= 0 ? '+' : '') + v + '%',
                  font: { family: "'JetBrains Mono'", size: 11 }
                },
                title: { display: true, text: 'Gain % vs capitale', color: '#7a7a90', font: { size: 11 } }
              },
              x: {
                grid: { display: false },
                ticks: { font: { family: "'JetBrains Mono'", size: 10 }, color: '#7a7a90', maxRotation: 0, autoSkip: true, autoSkipPadding: 14 }
              }
            }
          }
        });
      }

      if (variant === 'bars') {
        // Bar chart with 6 scenarios: 3 portfolio × 2 timing
        const labels = [];
        const data = [];
        const colors = [];
        const order = ['SPY', 'PESwitch', 'NoRot2', 'NoRot2_TS'];
        for (const p of order) {
          for (const t of ['1y_before', '1m_before']) {
            const s = crash.scenarios.find(x => x.portfolio === p && x.entry_offset === t);
            if (s) {
              labels.push(portfolioLabels[p] + (t === '1y_before' ? '\n(1y prima)' : '\n(1m prima)'));
              data.push(s.late_exit_gain_pct);
              colors.push(s.late_exit_gain_pct >= 0 ? '#00d26a' : portfolioColors[p]);
            }
          }
        }

        new Chart(ctx, {
          type: 'bar',
          data: {
            labels: labels,
            datasets: [{
              label: 'Late exit gain %',
              data: data,
              backgroundColor: colors,
              borderRadius: 6,
              borderSkipped: false
            }]
          },
          options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { display: false },
              tooltip: {
                backgroundColor: '#1a1a36',
                borderColor: 'rgba(255,255,255,0.1)',
                borderWidth: 1,
                padding: 12,
                callbacks: {
                  label: (ctx) => 'Late exit: ' + (ctx.parsed.x >= 0 ? '+' : '') + ctx.parsed.x.toFixed(1) + '%'
                }
              }
            },
            scales: {
              x: {
                grid: { color: 'rgba(255,255,255,0.05)' },
                ticks: {
                  callback: (v) => (v >= 0 ? '+' : '') + v + '%',
                  font: { family: "'JetBrains Mono'", size: 11 }
                }
              },
              y: {
                grid: { display: false },
                ticks: { font: { size: 11, weight: 600 }, color: '#f0f0f5' }
              }
            }
          }
        });
      }
      return;
    }

    if (id === 'chart-volcontrol') {
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: ['VIX 15→20', 'VIX 20→25', 'VIX 25→30', 'VIX 30→40'],
          datasets: [{
            label: 'Selling forzato (USD billions)',
            data: [30, 50, 80, 120],
            backgroundColor: ['#ffa502', '#ff8a3d', '#ff6b3d', '#ff4757'],
            borderRadius: 10,
            borderSkipped: false
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: '#1a1a36',
              borderColor: 'rgba(255,255,255,0.1)',
              borderWidth: 1,
              padding: 12,
              callbacks: {
                label: (ctx) => '$' + ctx.parsed.y + 'B vendite Vol Control'
              }
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              grid: { color: 'rgba(255,255,255,0.05)' },
              ticks: {
                callback: (v) => '$' + v + 'B',
                font: { family: "'JetBrains Mono'" }
              }
            },
            x: {
              grid: { display: false },
              ticks: {
                font: { weight: 600, family: "'JetBrains Mono'" },
                color: '#f0f0f5'
              }
            }
          }
        }
      });
    }
  }

  // Navigation events
  btnPrev.addEventListener('click', () => showSlide(currentIndex - 1));
  btnNext.addEventListener('click', () => showSlide(currentIndex + 1));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight' || e.key === ' ' || e.key === 'PageDown') {
      e.preventDefault();
      showSlide(currentIndex + 1);
    } else if (e.key === 'ArrowLeft' || e.key === 'PageUp') {
      e.preventDefault();
      showSlide(currentIndex - 1);
    } else if (e.key === 'Home') {
      e.preventDefault();
      showSlide(0);
    } else if (e.key === 'End') {
      e.preventDefault();
      showSlide(totalSlides - 1);
    } else if (e.key === 'f' || e.key === 'F') {
      if (!document.fullscreenElement) {
        document.documentElement.requestFullscreen?.();
      } else {
        document.exitFullscreen?.();
      }
    }
  });

  // Touch swipe
  let touchStartX = 0;
  let touchEndX = 0;
  document.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
  }, { passive: true });
  document.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    const dx = touchEndX - touchStartX;
    if (Math.abs(dx) > 60) {
      if (dx < 0) showSlide(currentIndex + 1);
      else showSlide(currentIndex - 1);
    }
  }, { passive: true });

  // Accordion handler for holdings rows with data-desc
  document.addEventListener('click', (e) => {
    const row = e.target.closest('.holdings-row[data-desc]');
    if (!row) return;
    e.stopPropagation();
    row.classList.toggle('is-expanded');
    const detail = row.nextElementSibling;
    if (detail && detail.classList.contains('holdings-detail')) {
      detail.classList.toggle('is-open');
    }
  });

  // Initialize first slide animations
  setTimeout(() => {
    animateCountersInSlide(slides[0]);
  }, 200);

  // Click on slide area to advance (optional)
  // (disabled to avoid conflict with future interactive elements)
})();
</script>
</body>
</html>
