      <tr><td style="padding:6px 10px;"><strong>Rate Hike 2022</strong></td><td style="padding:6px 10px;">1y</td><td class="num accent-red" style="padding:6px 10px;">−15,3%</td><td class="num accent-red" style="padding:6px 10px;">−16,1%</td><td class="num accent-red" style="padding:6px 10px;">−21,6%</td><td class="num accent-red" style="padding:6px 10px;">−22,2%</td><td style="padding:6px 10px;color:var(--accent-yellow);">SPY (sottile)</td></tr>
      <tr><td style="padding:6px 10px;">Rate Hike 2022</td><td style="padding:6px 10px;">1m</td><td class="num accent-red" style="padding:6px 10px;">−16,2%</td><td class="num accent-red" style="padding:6px 10px;">−21,8%</td><td class="num accent-red" style="padding:6px 10px;">−27,1%</td><td class="num accent-red" style="padding:6px 10px;">−30,5%</td><td style="padding:6px 10px;color:var(--accent-red);">SPY (perdono tutti)</td></tr>
