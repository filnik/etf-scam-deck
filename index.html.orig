<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gli ETF sono SCAM? — Slide deck stockpickers.app</title>
<meta name="description" content="Slide deck per video YouTube: perché gli ETF sono subottimali e come stockpickers.app + stock picking informato li batte di +15-25% CAGR.">
<meta name="theme-color" content="#0f0f1a">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@500;700&display=swap">

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-annotation@3.0.1/dist/chartjs-plugin-annotation.min.js"></script>

<style>
:root {
  --bg-primary: #0f0f1a;
  --bg-secondary: #141428;
  --bg-elevated: #1a1a36;
  --bg-glass: rgba(20, 20, 40, 0.6);
  --border-subtle: rgba(255, 255, 255, 0.06);
  --border-medium: rgba(255, 255, 255, 0.1);
  --border-strong: rgba(255, 255, 255, 0.15);
  --text-primary: #f0f0f5;
  --text-secondary: #b0b0c0;
  --text-muted: #7a7a90;
  --accent-cyan: #00d9ff;
  --accent-green: #00d26a;
  --accent-red: #ff4757;
  --accent-yellow: #ffa502;
  --accent-blue: #3498db;
  --accent-purple: #b388ff;
  --shadow-md: 0 8px 24px rgba(0, 0, 0, 0.4);
  --shadow-lg: 0 16px 48px rgba(0, 0, 0, 0.5);
  --shadow-glow-cyan: 0 0 60px rgba(0, 217, 255, 0.18);
  --shadow-glow-red: 0 0 60px rgba(255, 71, 87, 0.18);
  --shadow-glow-green: 0 0 60px rgba(0, 210, 106, 0.18);
  --font-heading: 'Inter', system-ui, -apple-system, sans-serif;
  --font-body: 'Inter', system-ui, -apple-system, sans-serif;
  --font-mono: 'JetBrains Mono', 'SF Mono', monospace;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
  height: 100%;
  overflow: hidden;
  background: var(--bg-primary);
  color: var(--text-primary);
  font-family: var(--font-body);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

body {
  display: flex;
  flex-direction: column;
}

/* Background ambient */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 50% at 20% 10%, rgba(0, 217, 255, 0.08), transparent 60%),
    radial-gradient(ellipse 60% 40% at 80% 90%, rgba(255, 71, 87, 0.05), transparent 60%),
    radial-gradient(ellipse 70% 50% at 50% 50%, rgba(0, 210, 106, 0.03), transparent 60%);
  z-index: 0;
  pointer-events: none;
}

body::after {
  content: '';
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  z-index: 1;
  pointer-events: none;
  mix-blend-mode: overlay;
  opacity: 0.6;
}

/* Progress bar */
.progress-bar {
  position: fixed;
  top: 0;
  left: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--accent-cyan), var(--accent-green));
  z-index: 100;
  width: 0%;
  transition: width 0.4s cubic-bezier(0.65, 0, 0.35, 1);
  box-shadow: 0 0 12px rgba(0, 217, 255, 0.6);
}

/* Branding header */
.deck-brand {
  position: fixed;
  top: 16px;
  left: 24px;
  z-index: 50;
  font-family: var(--font-heading);
  font-size: 14px;
  font-weight: 700;
  letter-spacing: -0.01em;
  color: var(--accent-cyan);
  text-shadow: 0 0 20px rgba(0, 217, 255, 0.5);
}
.deck-brand .dot {
  display: inline-block;
  width: 6px;
  height: 6px;
  background: var(--accent-cyan);
  border-radius: 50%;
  margin-right: 8px;
  vertical-align: middle;
  box-shadow: 0 0 12px var(--accent-cyan);
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* Slide container */
.deck {
  position: relative;
  z-index: 2;
  flex: 1;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.slide {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 80px 60px 120px;
  opacity: 0;
  transform: translateX(40px);
  pointer-events: none;
  transition: opacity 0.5s cubic-bezier(0.65, 0, 0.35, 1), transform 0.5s cubic-bezier(0.65, 0, 0.35, 1);
}

.slide.is-active {
  opacity: 1;
  transform: translateX(0);
  pointer-events: all;
}

.slide.is-prev {
  transform: translateX(-40px);
}

.slide-inner {
  width: 100%;
  max-width: 1280px;
  display: flex;
  flex-direction: column;
  gap: 32px;
}

/* Eyebrow / chapter label */
.eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--font-mono);
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent-cyan);
  padding: 6px 14px;
  background: rgba(0, 217, 255, 0.08);
  border: 1px solid rgba(0, 217, 255, 0.2);
  border-radius: 100px;
  width: fit-content;
}

/* Headings */
.h1 {
  font-family: var(--font-heading);
  font-size: clamp(48px, 6vw, 96px);
  font-weight: 900;
  letter-spacing: -0.04em;
  line-height: 0.95;
  color: var(--text-primary);
}

.h2 {
  font-family: var(--font-heading);
  font-size: clamp(36px, 4.5vw, 64px);
  font-weight: 800;
  letter-spacing: -0.03em;
  line-height: 1;
  color: var(--text-primary);
}

.h3 {
  font-family: var(--font-heading);
  font-size: clamp(24px, 2.4vw, 36px);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.15;
  color: var(--text-primary);
}

.lead {
  font-size: clamp(18px, 1.6vw, 24px);
  line-height: 1.5;
  color: var(--text-secondary);
  max-width: 920px;
}

.lead strong {
  color: var(--text-primary);
  font-weight: 700;
}

.muted {
  color: var(--text-muted);
  font-size: 14px;
  font-family: var(--font-mono);
}

.accent-cyan { color: var(--accent-cyan); }
.accent-green { color: var(--accent-green); }
.accent-red { color: var(--accent-red); }
.accent-yellow { color: var(--accent-yellow); }
.accent-purple { color: var(--accent-purple); }

.glitch {
  position: relative;
  color: var(--accent-red);
  text-shadow: 0 0 30px rgba(255, 71, 87, 0.5);
  animation: glitch-shift 4s infinite;
}
@keyframes glitch-shift {
  0%, 100% { transform: translate(0); }
  20% { transform: translate(-2px, 1px); }
  40% { transform: translate(2px, -1px); }
  60% { transform: translate(-1px, -2px); }
  80% { transform: translate(1px, 2px); }
}

/* Big number */
.big-number {
  font-family: var(--font-mono);
  font-weight: 700;
  font-size: clamp(80px, 14vw, 220px);
  line-height: 0.9;
  letter-spacing: -0.04em;
  display: inline-block;
}

.big-number--red {
  color: var(--accent-red);
  text-shadow: 0 0 80px rgba(255, 71, 87, 0.4);
}
.big-number--green {
  color: var(--accent-green);
  text-shadow: 0 0 80px rgba(0, 210, 106, 0.4);
}
.big-number--cyan {
  color: var(--accent-cyan);
  text-shadow: 0 0 80px rgba(0, 217, 255, 0.4);
}

/* Cards / glass */
.card {
  background: var(--bg-glass);
  backdrop-filter: blur(20px) saturate(1.2);
  -webkit-backdrop-filter: blur(20px) saturate(1.2);
  border: 1px solid var(--border-medium);
  border-radius: 20px;
  padding: 32px 36px;
  box-shadow: var(--shadow-md);
}

.card--glow-red {
  border-color: rgba(255, 71, 87, 0.3);
  box-shadow: var(--shadow-glow-red);
}
.card--glow-green {
  border-color: rgba(0, 210, 106, 0.3);
  box-shadow: var(--shadow-glow-green);
}
.card--glow-cyan {
  border-color: rgba(0, 217, 255, 0.3);
  box-shadow: var(--shadow-glow-cyan);
}

/* Comparison grid (vs) */
.vs-grid {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 24px;
  align-items: stretch;
}

.vs-grid .vs-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-mono);
  font-size: 24px;
  font-weight: 700;
  color: var(--text-muted);
}

.vs-card {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 28px;
  border-radius: 18px;
  background: var(--bg-glass);
  backdrop-filter: blur(20px);
  border: 1px solid var(--border-medium);
}

.vs-card__label {
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-muted);
}

.vs-card__title {
  font-size: 22px;
  font-weight: 700;
  color: var(--text-primary);
}

.vs-card__value {
  font-family: var(--font-mono);
  font-size: clamp(48px, 7vw, 88px);
  font-weight: 700;
  line-height: 1;
  letter-spacing: -0.03em;
}

.vs-card__sub {
  font-family: var(--font-mono);
  font-size: 14px;
  color: var(--text-secondary);
}

.vs-card--loss { border-color: rgba(255, 71, 87, 0.25); }
.vs-card--loss .vs-card__value { color: var(--accent-red); }
.vs-card--win { border-color: rgba(0, 210, 106, 0.25); }
.vs-card--win .vs-card__value { color: var(--accent-green); }

/* Holdings table */
.holdings {
  display: flex;
  flex-direction: column;
  gap: 6px;
  font-family: var(--font-mono);
  font-size: 16px;
}

.holdings-row {
  display: grid;
  grid-template-columns: 32px 1fr 100px 32px;
  align-items: center;
  gap: 16px;
  padding: 12px 18px;
  background: var(--bg-glass);
  backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
  transition: all 0.2s ease;
}

.holdings-row.is-bad {
  border-color: rgba(255, 71, 87, 0.25);
  background: rgba(255, 71, 87, 0.06);
}

.holdings-row.is-good {
  border-color: rgba(0, 210, 106, 0.18);
}

.holdings-row__rank {
  font-weight: 700;
  color: var(--text-muted);
  font-size: 13px;
}

.holdings-row__name {
  font-weight: 600;
  font-family: var(--font-body);
  color: var(--text-primary);
}

.holdings-row__weight {
  text-align: right;
  font-weight: 700;
  color: var(--accent-cyan);
}

.holdings-row__verdict {
  text-align: center;
  font-size: 18px;
}

.holdings-row.is-bad .holdings-row__verdict { color: var(--accent-red); }
.holdings-row.is-good .holdings-row__verdict { color: var(--accent-green); }

/* Accordion holdings */
.holdings-row[data-desc] {
  cursor: pointer;
  user-select: none;
}
.holdings-row[data-desc]:hover {
  border-color: var(--accent-cyan);
  background: rgba(0, 217, 255, 0.05);
}
.holdings-row[data-desc]::after {
  content: '+';
  position: absolute;
  right: 14px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-muted);
  font-size: 14px;
  font-weight: 700;
  transition: transform 0.2s ease;
}
.holdings-row[data-desc] {
  position: relative;
  padding-right: 38px;
}
.holdings-row.is-expanded::after {
  transform: translateY(-50%) rotate(45deg);
  color: var(--accent-cyan);
}
.holdings-detail {
  max-height: 0;
  overflow: hidden;
  font-family: var(--font-body);
  font-size: 13px;
  line-height: 1.45;
  color: var(--text-secondary);
  padding: 0 18px;
  margin-top: 0;
  margin-bottom: 0;
  background: rgba(0, 217, 255, 0.04);
  border-left: 2px solid var(--accent-cyan);
  border-radius: 0 8px 8px 0;
  transition: max-height 0.3s cubic-bezier(0.65, 0, 0.35, 1), padding 0.3s ease, margin 0.3s ease;
}
.holdings-detail.is-open {
  max-height: 200px;
  padding: 12px 18px;
  margin-top: 4px;
  margin-bottom: 6px;
}

/* Compact holdings — for dense slides with many rows (es. confronto 15 vs 10) */
.holdings--tight { gap: 3px; }
.holdings--tight .holdings-row { padding: 6px 16px; }
.holdings--tight .holdings-row[data-desc] { padding-right: 32px; }
.holdings--tight .holdings-row__verdict { font-size: 15px; }

/* Confronto ETF vs vero momentum (slide 14b) — griglie colonna dedicate */
.cmp-etf .holdings-row  { grid-template-columns: 24px 1fr 48px 64px; }
.cmp-real .holdings-row { grid-template-columns: 24px 1fr 60px; }
.cmp-etf .holdings-row__mom { text-align: right; font-weight: 600; color: var(--text-secondary); }

/* Confronto 3 colonne (slide 14b): ETF · momentum raw · momentum filtrato */
.cmp3 { font-size: 11px; }
.cmp3 .holdings-row { padding: 5px 11px; gap: 7px; }
.cmp3-etf  .holdings-row { grid-template-columns: 18px 1fr 40px 38px 70px; }
.cmp3-real .holdings-row { grid-template-columns: 20px 1fr 50px; }
.cmp3 .holdings-row__weight { text-align: right; font-weight: 600; color: var(--text-secondary); }
.cmp3 .holdings-row__clenow { text-align: right; font-weight: 700; color: var(--accent-cyan); font-family: var(--font-mono); }
.cmp3 .holdings-row__verdict { text-align: right; font-size: 11px; }
.cmp3 .holdings-row__verdict .ok { color: var(--accent-green); font-weight: 700; font-size: 13px; }
.brk-badge {
  display: inline-block; font-family: var(--font-mono); font-size: 9px;
  font-weight: 700; padding: 1px 5px; border-radius: 5px; letter-spacing: 0.02em;
  background: rgba(255, 71, 87, 0.16); color: var(--accent-red); white-space: nowrap;
}

/* Data table */
.data-table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  font-family: var(--font-mono);
  font-size: 16px;
}
.data-table th, .data-table td {
  padding: 14px 18px;
  text-align: left;
  border-bottom: 1px solid var(--border-subtle);
}
.data-table th {
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-muted);
  font-weight: 500;
}
.data-table td.num {
  text-align: right;
  font-weight: 700;
}
.data-table tr.highlight td {
  background: rgba(255, 71, 87, 0.08);
  border-color: rgba(255, 71, 87, 0.2);
}

/* List */
.bullet-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
  font-size: clamp(18px, 1.8vw, 26px);
  line-height: 1.4;
  color: var(--text-secondary);
}

.bullet-list li {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  list-style: none;
}

.bullet-list li::before {
  content: '';
  flex-shrink: 0;
  width: 8px;
  height: 8px;
  margin-top: 14px;
  background: var(--accent-cyan);
  border-radius: 50%;
  box-shadow: 0 0 12px var(--accent-cyan);
}

.bullet-list li strong {
  color: var(--text-primary);
  font-weight: 700;
}

.bullet-list--numbered {
  counter-reset: bullet;
}
.bullet-list--numbered li::before {
  counter-increment: bullet;
  content: counter(bullet, decimal-leading-zero);
  width: auto;
  height: auto;
  margin-top: 0;
  background: none;
  border-radius: 0;
  box-shadow: none;
  font-family: var(--font-mono);
  font-size: 18px;
  font-weight: 700;
  color: var(--accent-cyan);
  min-width: 36px;
}

/* Quote card */
.quote {
  font-family: var(--font-heading);
  font-style: italic;
  font-size: clamp(28px, 3.2vw, 48px);
  font-weight: 500;
  line-height: 1.2;
  letter-spacing: -0.02em;
  color: var(--text-primary);
  border-left: 4px solid var(--accent-cyan);
  padding: 8px 28px;
}

.quote-author {
  font-family: var(--font-mono);
  font-style: normal;
  font-size: 14px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-top: 16px;
  display: block;
}

/* Crash table */
.crash-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}
.crash-item {
  padding: 28px 24px;
  background: var(--bg-glass);
  backdrop-filter: blur(20px);
  border: 1px solid var(--border-medium);
  border-radius: 16px;
  text-align: center;
}
.crash-item__ticker {
  font-family: var(--font-mono);
  font-size: 18px;
  font-weight: 700;
  color: var(--text-muted);
  letter-spacing: 0.05em;
  margin-bottom: 8px;
}
.crash-item__value {
  font-family: var(--font-mono);
  font-size: clamp(36px, 4vw, 56px);
  font-weight: 700;
  letter-spacing: -0.03em;
  margin-bottom: 8px;
}
.crash-item__label {
  font-size: 12px;
  color: var(--text-muted);
  font-family: var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.crash-item--down .crash-item__value { color: var(--accent-red); }
.crash-item--up .crash-item__value { color: var(--accent-green); }

/* Chart container */
.chart-wrapper {
  width: 100%;
  height: 420px;
  background: var(--bg-glass);
  backdrop-filter: blur(20px);
  border: 1px solid var(--border-medium);
  border-radius: 18px;
  padding: 20px 24px;
  position: relative;
}

/* Footer disclaimer */
.disclaimer-tag {
  position: fixed;
  bottom: 24px;
  left: 24px;
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--text-muted);
  z-index: 30;
  letter-spacing: 0.05em;
}

/* Navigation */
.nav-controls {
  position: fixed;
  bottom: 24px;
  right: 24px;
  display: flex;
  align-items: center;
  gap: 12px;
  z-index: 50;
  background: var(--bg-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-medium);
  border-radius: 100px;
  padding: 8px;
  box-shadow: var(--shadow-md);
}

.nav-btn {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: none;
  background: rgba(255, 255, 255, 0.05);
  color: var(--text-primary);
  font-size: 18px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.nav-btn:hover {
  background: var(--accent-cyan);
  color: var(--bg-primary);
  transform: translateY(-1px);
  box-shadow: 0 0 20px rgba(0, 217, 255, 0.4);
}

.nav-btn:disabled {
  opacity: 0.3;
  cursor: not-allowed;
  transform: none;
}

.nav-counter {
  font-family: var(--font-mono);
  font-size: 14px;
  font-weight: 600;
  color: var(--text-secondary);
  padding: 0 12px;
  letter-spacing: 0.05em;
  min-width: 64px;
  text-align: center;
}

.nav-counter .current {
  color: var(--accent-cyan);
}

/* Highlight emphasis box */
.emphasis-box {
  display: inline-block;
  padding: 4px 14px;
  border-radius: 8px;
  background: rgba(0, 217, 255, 0.1);
  border: 1px solid rgba(0, 217, 255, 0.3);
  color: var(--accent-cyan);
  font-weight: 700;
}

.emphasis-box--red {
  background: rgba(255, 71, 87, 0.1);
  border-color: rgba(255, 71, 87, 0.3);
  color: var(--accent-red);
}

.emphasis-box--green {
  background: rgba(0, 210, 106, 0.1);
  border-color: rgba(0, 210, 106, 0.3);
  color: var(--accent-green);
}

/* Specific layouts */
.layout-center {
  text-align: center;
  align-items: center;
}
.layout-center .lead { margin: 0 auto; }

.split-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  align-items: start;
}

.split-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

/* Hero label badge */
.cta-badge {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  padding: 14px 28px;
  background: linear-gradient(135deg, var(--accent-cyan) 0%, var(--accent-blue) 100%);
  color: var(--bg-primary);
  border-radius: 100px;
  font-weight: 700;
  font-size: 18px;
  text-decoration: none;
  box-shadow: 0 8px 32px rgba(0, 217, 255, 0.3);
  transition: transform 0.2s ease;
}

.cta-badge:hover { transform: translateY(-2px); }

/* Source citation */
.source {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--text-muted);
  letter-spacing: 0.05em;
  font-style: italic;
  margin-top: auto;
}

/* Tech analogy slide */
.analogy-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
}
.analogy-card {
  padding: 32px 28px;
  background: var(--bg-glass);
  backdrop-filter: blur(20px);
  border: 1px solid var(--border-medium);
  border-radius: 18px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.analogy-card__icon {
  font-size: 56px;
  line-height: 1;
}
.analogy-card__era {
  font-family: var(--font-mono);
  font-size: 13px;
  letter-spacing: 0.1em;
  color: var(--accent-cyan);
  text-transform: uppercase;
}
.analogy-card__title {
  font-size: 22px;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.2;
}
.analogy-card__desc {
  font-size: 15px;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* Print / fullscreen */
@media print {
  body { overflow: visible; }
  .nav-controls, .progress-bar, .deck-brand, .disclaimer-tag { display: none; }
  .slide {
    position: relative;
    inset: auto;
    opacity: 1;
    transform: none;
    page-break-after: always;
    min-height: 100vh;
  }
}

/* Mobile */
@media (max-width: 768px) {
  .slide { padding: 60px 24px 100px; }
  .vs-grid { grid-template-columns: 1fr; }
  .vs-grid .vs-divider { padding: 8px 0; }
  .crash-grid { grid-template-columns: repeat(2, 1fr); }
  .split-2, .split-3, .analogy-grid { grid-template-columns: 1fr; }
  .deck-brand { font-size: 12px; left: 16px; }
  .nav-controls { right: 16px; bottom: 16px; }
}
</style>
</head>
<body>

<div class="progress-bar" id="progressBar"></div>

<div class="deck-brand">
  <span class="dot"></span>stockpickers.app
</div>

